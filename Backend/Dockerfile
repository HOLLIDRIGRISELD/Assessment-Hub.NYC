# USE JAVA 17 BASE IMAGE FOR SPRING BOOT APPLICATION
FROM eclipse-temurin:17-jdk-alpine

# SET WORKING DIRECTORY INSIDE CONTAINER
WORKDIR /app

# COPY MAVEN WRAPPER AND CONFIG FILES
COPY mvnw .
COPY .mvn .mvn
COPY pom.xml .

# GIVE EXECUTION PERMISSION TO MAVEN WRAPPER
RUN chmod +x ./mvnw

# DOWNLOAD ALL DEPENDENCIES FOR CACHING
RUN ./mvnw dependency:go-offline -B

# COPY SOURCE CODE INTO CONTAINER
COPY src src

# BUILD APPLICATION AND SKIP TESTS
RUN ./mvnw package -DskipTests

# RUN THE GENERATED JAR FILE AUTOMATICALLY
ENTRYPOINT ["sh", "-c", "java -jar target/*.jar"]